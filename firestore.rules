rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validProduct() {
      return request.resource.data.keys().hasAll([
        'name', 'category', 'material', 'price', 'stock', 'sku', 'weight', 'image', 'description'
      ])
      && request.resource.data.name is string
      && request.resource.data.category is string
      && request.resource.data.material is string
      && request.resource.data.price is number
      && request.resource.data.price >= 0
      && request.resource.data.stock is number
      && request.resource.data.stock >= 0
      && request.resource.data.sku is string
      && request.resource.data.weight is string
      && request.resource.data.image is string
      && request.resource.data.description is string;
    }

    function validCustomer() {
      return request.resource.data.keys().hasAll([
        'name', 'email', 'phone', 'orders', 'joined', 'totalSpent', 'vip'
      ])
      && request.resource.data.name is string
      && request.resource.data.email is string
      && request.resource.data.phone is string
      && request.resource.data.orders is number
      && request.resource.data.orders >= 0
      && request.resource.data.joined is string
      && request.resource.data.totalSpent is number
      && request.resource.data.totalSpent >= 0
      && request.resource.data.vip is bool;
    }

    function validOrder() {
      return request.resource.data.keys().hasAll([
        'date', 'customer', 'address', 'payment', 'status', 'items', 'total'
      ])
      && request.resource.data.date is string
      && request.resource.data.customer is string
      && request.resource.data.address is string
      && request.resource.data.payment is string
      && request.resource.data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled']
      && request.resource.data.items is list
      && request.resource.data.total is number
      && request.resource.data.total >= 0;
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validProduct();
      allow delete: if signedIn();
    }

    match /customers/{customerId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validCustomer();
      allow delete: if signedIn();
    }

    match /orders/{orderId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validOrder();
      allow delete: if signedIn();
    }

    match /meta/{docId} {
      allow read, write: if signedIn();
    }

    // Each admin's own profile: any signed-in admin can read the directory,
    // but you can only create/update/delete your own document.
    match /admins/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
